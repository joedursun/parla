{
  "$schema": "https://raw.githubusercontent.com/nickelpack/nk/refs/heads/main/schema/tauri/2/tauri.conf.json",
  "productName": "Parla",
  "version": "0.1.0",
  "identifier": "com.parla.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Parla",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
